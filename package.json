{
  "name": "minimax-usage-statusbar",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "icon": "images/icon.png",
  "version": "0.0.13",
  "publisher": "decard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nextransit/minimax-usgae-plugin.git"
  },
  "type": "commonjs",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:minimaxUsage.showDetails",
    "onCommand:minimaxUsage.refresh",
    "onCommand:minimaxUsage.setApiKey",
    "onCommand:minimaxUsage.manageApiKeys",
    "onCommand:minimaxUsage.clearApiKey",
    "onCommand:minimaxUsage.copyRawResponse",
    "onCommand:minimaxUsage.addApiKey",
    "onCommand:minimaxUsage.updateApiKey",
    "onCommand:minimaxUsage.deleteApiKey",
    "onCommand:minimaxUsage.reorderApiKeys",
    "onCommand:minimaxUsage.showKeySwitcher",
    "onCommand:minimaxUsage.refreshAll"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "minimaxUsage.refresh",
        "title": "%command.refresh.title%"
      },
      {
        "command": "minimaxUsage.showDetails",
        "title": "%command.showDetails.title%"
      },
      {
        "command": "minimaxUsage.setApiKey",
        "title": "%command.setApiKey.title%"
      },
      {
        "command": "minimaxUsage.clearApiKey",
        "title": "%command.clearApiKey.title%"
      },
      {
        "command": "minimaxUsage.copyRawResponse",
        "title": "%command.copyRawResponse.title%"
      },
      {
        "command": "minimaxUsage.addApiKey",
        "title": "Add API Key"
      },
      {
        "command": "minimaxUsage.updateApiKey",
        "title": "Update API Key"
      },
      {
        "command": "minimaxUsage.deleteApiKey",
        "title": "Delete API Key"
      },
      {
        "command": "minimaxUsage.reorderApiKeys",
        "title": "Reorder API Keys"
      },
      {
        "command": "minimaxUsage.showKeySwitcher",
        "title": "Switch API Key"
      },
      {
        "command": "minimaxUsage.refreshAll",
        "title": "Refresh All Keys"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "minimaxUsage.refreshIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "maximum": 3600,
          "description": "%configuration.refreshIntervalSeconds.description%"
        },
        "minimaxUsage.showWeeklyInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.showWeeklyInStatusBar.description%"
        },
        "minimaxUsage.detailModelLimit": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 30,
          "description": "%configuration.detailModelLimit.description%"
        },
        "minimaxUsage.statusBarAlignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "%configuration.statusBarAlignment.description%"
        },
        "minimaxUsage.requestTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 3000,
          "maximum": 60000,
          "description": "%configuration.requestTimeoutMs.description%"
        },
        "minimaxUsage.language": {
          "type": "string",
          "enum": [
            "auto",
            "zh-CN",
            "en"
          ],
          "default": "auto",
          "description": "%configuration.language.description%",
          "enumDescriptions": [
            "%configuration.language.auto%",
            "%configuration.language.zhCN%",
            "%configuration.language.en%"
          ]
        },
        "minimaxUsage.apiKeys": {
          "type": "array",
          "default": [],
          "description": "List of configured API keys",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "color": {
                "type": "string"
              },
              "refreshInterval": {
                "type": "number"
              },
              "createdAt": {
                "type": "number"
              },
              "isActive": {
                "type": "boolean"
              }
            }
          }
        },
        "minimaxUsage.selectedKeyId": {
          "type": "string",
          "default": "ALL",
          "description": "Currently selected API key ID"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "echo \"No tests configured\"",
    "package": "vsce package",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:ci": "tauri build --ci --no-sign",
    "tauri:info": "tauri info",
    "tauri:build:linux:remote": "bash scripts/remote-linux-build.sh",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.107.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^6.0.2"
  }
}
