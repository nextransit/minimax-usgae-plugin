{
  "name": "minimax-usage-statusbar",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "icon": "images/icon.png",
  "version": "0.0.8",
  "publisher": "decard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://192.168.19.70/ai/minimax-usgae-plugin.git"
  },
  "type": "commonjs",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:minimaxUsage.showDetails",
    "onCommand:minimaxUsage.refresh",
    "onCommand:minimaxUsage.setApiKey",
    "onCommand:minimaxUsage.clearApiKey",
    "onCommand:minimaxUsage.copyRawResponse"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "minimaxUsage.refresh",
        "title": "%command.refresh.title%"
      },
      {
        "command": "minimaxUsage.showDetails",
        "title": "%command.showDetails.title%"
      },
      {
        "command": "minimaxUsage.setApiKey",
        "title": "%command.setApiKey.title%"
      },
      {
        "command": "minimaxUsage.clearApiKey",
        "title": "%command.clearApiKey.title%"
      },
      {
        "command": "minimaxUsage.copyRawResponse",
        "title": "%command.copyRawResponse.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "minimaxUsage.refreshIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "maximum": 3600,
          "description": "%configuration.refreshIntervalSeconds.description%"
        },
        "minimaxUsage.showWeeklyInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.showWeeklyInStatusBar.description%"
        },
        "minimaxUsage.detailModelLimit": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 30,
          "description": "%configuration.detailModelLimit.description%"
        },
        "minimaxUsage.statusBarAlignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "%configuration.statusBarAlignment.description%"
        },
        "minimaxUsage.requestTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 3000,
          "maximum": 60000,
          "description": "%configuration.requestTimeoutMs.description%"
        },
        "minimaxUsage.language": {
          "type": "string",
          "enum": [
            "auto",
            "zh-CN",
            "en"
          ],
          "default": "auto",
          "description": "%configuration.language.description%",
          "enumDescriptions": [
            "%configuration.language.auto%",
            "%configuration.language.zhCN%",
            "%configuration.language.en%"
          ]
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "echo \"No tests configured\"",
    "package": "vsce package --baseContentUrl https://192.168.19.70/ai/minimax-usgae-plugin/-/raw/master --baseImagesUrl https://192.168.19.70/ai/minimax-usgae-plugin/-/raw/master",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:ci": "tauri build --ci --no-sign",
    "tauri:info": "tauri info",
    "tauri:build:linux:remote": "bash scripts/remote-linux-build.sh"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.107.0",
    "typescript": "^6.0.2"
  }
}
